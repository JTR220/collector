# Image de DÉVELOPPEMENT uniquement (serveur Vite + HMR), utilisée par
# apps/docker-compose.yml. L'image de production est ./Dockerfile.
FROM node:26.3-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV HOST=0.0.0.0
ENV PORT=5173
# URLs d'API lues au runtime via $env/dynamic/public (préfixe PUBLIC_).
ENV PUBLIC_CATALOG_API_BASE_URL=http://localhost:8081

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
